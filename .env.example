# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Google Sheets
SPREADSHEET_ID=your-spreadsheet-id
SHEET_NAME=Sheet1
GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key

# Access Control — comma-separated Slack channel IDs (leave empty to allow all channels)
# Find channel IDs: right-click a channel in Slack → "View channel details" → scroll to bottom
ALLOWED_CHANNEL_IDS=C01EXAMPLE1,C02EXAMPLE2